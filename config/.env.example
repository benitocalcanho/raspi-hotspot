# ============================================================
#  raspi-hotspot — Environment Configuration
#  Copy this file to config/.env and fill in ALL values.
#  NEVER commit config/.env to version control.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_STRONG_RANDOM_SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_STRONG_JWT_SECRET_KEY

# ── Database ─────────────────────────────────────────────────
# Docker: use the absolute path below (matches the named volume mount)
# Manual install: use the relative path (relative to backend/ working dir)
DATABASE_URL=sqlite:///data/raspi.db

# ── Admin (first-boot bootstrap) ─────────────────────────────
ADMIN_USERNAME=admin
# Use a strong password — this is your main admin account
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Permanent non-admin cleaner account
CLEANER_USERNAME=cleaner
CLEANER_PASSWORD=CHANGE_ME_CLEANER_PASSWORD

# ── WiFi Hotspot ─────────────────────────────────────────────
# SSID and passphrase for the setup hotspot
HOTSPOT_SSID=RaspiSetup
HOTSPOT_PASSPHRASE=raspisetup123
# Optional: force the WiFi interface used for hotspot/client mode
# Leave empty for auto-detection (recommended). Example: wlan0
WIFI_IFACE=
# IP given to the Pi on the hotspot interface
HOTSPOT_IP=192.168.50.1
HOTSPOT_DHCP_RANGE=192.168.50.10,192.168.50.50

# ── ngrok ────────────────────────────────────────────────────
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=CHANGE_ME_NGROK_AUTHTOKEN
# Optional: your free static ngrok domain (ngrok free tier gives 1 static domain)
# Leave empty to use a random subdomain
NGROK_STATIC_DOMAIN=


# ── iCal Calendar ───────────────────────────────────────────
# Paste the private iCal URL from Google Calendar → Settings → "Secret address in iCal format"
ICAL_URL=
ICAL_GUEST_PASSWORD=
# Guest rotation schedule (HH:MM, 24h)
CHECKOUT_TIME=12:00
CHECKIN_TIME=14:00
# Fixed password used for all calendar-created guests
CALENDAR_GUEST_DEFAULT_PASSWORD=CHANGE_ME_GUEST_PASSWORD
CALENDAR_SYNC_ENABLED=true
# How often to poll iCal for new events (seconds)
CALENDAR_SYNC_INTERVAL=300

# ── GPIO ─────────────────────────────────────────────────────
# Set to 'mock' on non-Pi systems for development; 'gpiozero' on real Pi
GPIO_MODE=gpiozero
# Enable GPIO API routes. Keep false on PC, set true on Raspberry Pi.
ENABLE_GPIO=false

# ── Tailscale ────────────────────────────────────────────────
# Subnet reserved for Tailscale peers (used to restrict admin-only routes)
TAILSCALE_SUBNET=100.64.0.0/10
# Require admin requests to come from Tailscale IPs.
# Default is local-first. Set true only if you want strict remote admin restriction.
ADMIN_REQUIRE_TAILSCALE=false

# ── Application ──────────────────────────────────────────────
APP_PORT=5000
# Host to bind Flask to ('0.0.0.0' to accept all interfaces)
APP_HOST=0.0.0.0
# How often to poll Google Calendar for new events (seconds)
CALENDAR_SYNC_INTERVAL=300

# ── Email/SMTP (for notifications) ─────────────────────────
# SMTP server host (e.g. smtp.gmail.com)
SMTP_HOST=
# SMTP port (usually 587 for TLS)
SMTP_PORT=587
# SMTP username (your email address)
SMTP_USER=
# SMTP password (app password or real password)
SMTP_PASS=
# Sender email address (e.g. notifications@yourdomain.com)
EMAIL_SENDER=
# Recipient email address (where notifications are sent)
EMAIL_RECIPIENT=
