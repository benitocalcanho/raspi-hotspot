# ============================================================
#  raspi-hotspot — Environment Configuration
#
#  Default values are pre-filled for plug-and-play use.
#  Fill in the blank fields marked with  ← YOUR ...
#  NEVER commit config/.env to version control.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production
# Used to sign sessions. Change this on any public-facing install.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=raspi-hotspot-default-secret-key-change-me
JWT_SECRET_KEY=raspi-hotspot-default-jwt-key-change-me

# ── Database ─────────────────────────────────────────────────
# Matches the named Docker volume mount. Do not change unless you know why.
DATABASE_URL=sqlite:///data/raspi.db

# ── Admin account (created on first boot) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# ── Cleaner account (permanent, non-admin) ───────────────────
CLEANER_USERNAME=cleaner
CLEANER_PASSWORD=cleaner12345

# ── Application ──────────────────────────────────────────────
APP_PORT=5000
APP_HOST=0.0.0.0

# ── GPIO ─────────────────────────────────────────────────────
# 'mock' on PC/Docker Desktop (no real hardware); 'gpiozero' on Raspberry Pi
GPIO_MODE=mock
# Set true only on a real Raspberry Pi with wired GPIO relays
ENABLE_GPIO=false

# ── iCal Calendar (optional) ────────────────────────────────
# Leave ICAL_URL blank to disable calendar sync entirely.
# Paste the private iCal URL from Google Calendar → Settings → "Secret address in iCal format"
ICAL_URL=
# Optional: password used for a password-protected iCal feed
ICAL_GUEST_PASSWORD=
# Password assigned to every guest account created from the calendar
CALENDAR_GUEST_DEFAULT_PASSWORD=guest12345
# Guest check-in / check-out times (HH:MM, 24h)
CHECKOUT_TIME=12:00
CHECKIN_TIME=14:00
CALENDAR_SYNC_ENABLED=true
# How often to poll iCal for changes (seconds)
CALENDAR_SYNC_INTERVAL=300

# ── WiFi Hotspot (Raspberry Pi only) ────────────────────────
HOTSPOT_SSID=RaspiSetup
HOTSPOT_PASSPHRASE=raspisetup123
# Leave blank for auto-detection; example: wlan0
WIFI_IFACE=
HOTSPOT_IP=192.168.50.1
HOTSPOT_DHCP_RANGE=192.168.50.10,192.168.50.50

# ── Tailscale ────────────────────────────────────────────────
TAILSCALE_SUBNET=100.64.0.0/10
ADMIN_REQUIRE_TAILSCALE=false

# ── ngrok (optional — remote access without port forwarding) ─
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Optional: your free static ngrok domain (leave blank for random subdomain)
NGROK_STATIC_DOMAIN=

# ── Email / SMTP (optional — for notifications) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_SENDER=
EMAIL_RECIPIENT=
