# Copy this file to .env and fill in your values.
# .env is gitignored — it will never be committed.

# Flask security keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Cleaner account
CLEANER_USERNAME=cleaner
CLEANER_PASSWORD=cleaner12345

# ngrok remote access
NGROK_AUTHTOKEN=
NGROK_STATIC_DOMAIN=

# Calendar guest default password
CALENDAR_GUEST_DEFAULT_PASSWORD=guest12345
